{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": ".temp/compiled",
    "rootDir": ".",
    "declaration": true,
    "composite": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "tsBuildInfoFile": ".temp/compiled/tsconfig.rayfin.tsbuildinfo"
  },
  "include": ["**/*"],
  "exclude": [".temp/**/*"]
}
